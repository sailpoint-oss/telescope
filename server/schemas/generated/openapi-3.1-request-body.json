{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "$ref": "#/$defs/__schema0"
    },
    {
      "$ref": "#/$defs/__schema8"
    }
  ],
  "title": "RequestBody",
  "description": "Describes a single request body.",
  "$defs": {
    "__schema0": {
      "type": "object",
      "properties": {
        "$ref": {
          "$ref": "#/$defs/__schema1"
        },
        "summary": {
          "$ref": "#/$defs/__schema5"
        },
        "description": {
          "$ref": "#/$defs/__schema6"
        }
      },
      "required": [
        "$ref"
      ],
      "additionalProperties": false,
      "title": "Reference Object",
      "description": "A reference to another component in the specification.",
      "examples": [
        {
          "$ref": "#/components/schemas/Pet"
        },
        {
          "$ref": "./schemas/User.yaml",
          "summary": "A user",
          "description": "A user is a type of person."
        },
        {
          "$ref": "definitions.yaml#/Pet",
          "summary": "A pet",
          "description": "A pet is a type of animal."
        },
        {
          "$ref": "https://example.com/schemas/Pet.yaml",
          "summary": "A pet",
          "description": "A pet is a type of animal."
        }
      ]
    },
    "__schema1": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema2"
        },
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        }
      ],
      "title": "Reference",
      "description": "A reference to another component in the specification.",
      "examples": [
        "#/components/schemas/Pet",
        "https://example.com/schemas/Pet.yaml",
        "./schemas/Pet.yaml"
      ]
    },
    "__schema2": {
      "type": "string",
      "pattern": "^#.*",
      "title": "Internal JSON Pointer Reference",
      "description": "Internal JSON Pointer reference",
      "examples": [
        "#/components/schemas/User",
        "#/components/schemas/Error",
        "#/components/responses/NotFound",
        "#/components/parameters/PageParam",
        "#/components/requestBodies/UserInput"
      ]
    },
    "__schema3": {
      "type": "string",
      "pattern": "^https?:\\/\\/",
      "title": "URL Reference",
      "description": "URL reference",
      "examples": [
        "https://example.com/schemas/Pet.yaml",
        "https://example.com/schemas/User.json",
        "https://example.com/responses/Not-Found-Error.yaml",
        "https://example.com/parameters.yaml#/PageParam",
        "https://example.com/requestBodies.yaml#/requestBodies/UserInput"
      ]
    },
    "__schema4": {
      "type": "string",
      "pattern": "^[^#\\s]+(\\.ya?ml|\\.json)(#\\/.*)?$",
      "title": "Relative File Reference",
      "description": "Relative file reference",
      "examples": [
        "./schemas/Pet.yaml",
        "../common/types.yaml",
        "schemas/Pet.yaml",
        "./v2/components/parameters.yaml#/components/parameters/LimitParam",
        "../common/types.yaml#/properties/id",
        "schemas/Pet.yaml#/properties/name"
      ]
    },
    "__schema5": {
      "type": "string",
      "title": "summary",
      "description": "A short summary which by default SHOULD override that of the referenced component."
    },
    "__schema6": {
      "type": "string",
      "title": "description",
      "description": "A description which by default SHOULD override that of the referenced component."
    },
    "__schema8": {
      "type": "object",
      "properties": {
        "description": {
          "$ref": "#/$defs/__schema9"
        },
        "content": {
          "$ref": "#/$defs/__schema11"
        },
        "required": {
          "$ref": "#/$defs/__schema204"
        }
      },
      "required": [
        "content"
      ],
      "additionalProperties": false,
      "title": "RequestBody",
      "description": "Describes a single request body.",
      "examples": [
        {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        }
      ]
    },
    "__schema9": {
      "title": "description",
      "$ref": "#/$defs/__schema10"
    },
    "__schema10": {
      "type": "string"
    },
    "__schema11": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/__schema12"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema13"
      },
      "title": "content"
    },
    "__schema12": {
      "type": "string"
    },
    "__schema13": {
      "type": "object",
      "properties": {
        "schema": {
          "$ref": "#/$defs/__schema14"
        },
        "example": {
          "$ref": "#/$defs/__schema153"
        },
        "examples": {
          "$ref": "#/$defs/__schema155"
        },
        "encoding": {
          "$ref": "#/$defs/__schema164"
        }
      },
      "additionalProperties": false,
      "title": "MediaType",
      "description": "Each Media Type Object provides schema and examples for the media type identified by its key.",
      "examples": [
        {
          "schema": {
            "type": "object"
          },
          "example": {
            "id": 1
          }
        }
      ]
    },
    "__schema14": {
      "title": "schema",
      "$ref": "#/$defs/__schema15"
    },
    "__schema15": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema0"
        },
        {
          "$ref": "#/$defs/__schema16"
        },
        {
          "$ref": "#/$defs/__schema54"
        },
        {
          "$ref": "#/$defs/__schema66"
        },
        {
          "$ref": "#/$defs/__schema79"
        },
        {
          "$ref": "#/$defs/__schema92"
        },
        {
          "$ref": "#/$defs/__schema94"
        },
        {
          "$ref": "#/$defs/__schema96"
        },
        {
          "$ref": "#/$defs/__schema114"
        },
        {
          "$ref": "#/$defs/__schema138"
        }
      ],
      "title": "Schema Object",
      "description": "A Schema Object defines the shape of a JSON value.",
      "examples": [
        {
          "type": "string",
          "format": "email"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "__schema16": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema17"
        },
        "description": {
          "$ref": "#/$defs/__schema18"
        },
        "default": {
          "$ref": "#/$defs/__schema19"
        },
        "example": {
          "$ref": "#/$defs/__schema20"
        },
        "examples": {
          "$ref": "#/$defs/__schema21"
        },
        "enum": {
          "$ref": "#/$defs/__schema23"
        },
        "const": {
          "$ref": "#/$defs/__schema25"
        },
        "discriminator": {
          "$ref": "#/$defs/__schema26"
        },
        "xml": {
          "$ref": "#/$defs/__schema33"
        },
        "externalDocs": {
          "$ref": "#/$defs/__schema43"
        },
        "readOnly": {
          "$ref": "#/$defs/__schema48"
        },
        "writeOnly": {
          "$ref": "#/$defs/__schema49"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema50"
        },
        "type": {
          "$ref": "#/$defs/__schema51"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "title": "Type Array Schema",
      "description": "OpenAPI 3.1 (JSON Schema) allows type to be an array of primitive types.",
      "examples": [
        {
          "type": [
            "string",
            "null"
          ]
        }
      ]
    },
    "__schema17": {
      "type": "string",
      "title": "title",
      "examples": [
        "Pet",
        "User",
        "Order",
        "Error"
      ],
      "description": "A title for the schema, used for documentation."
    },
    "__schema18": {
      "type": "string",
      "title": "description",
      "examples": [
        "A pet in the store",
        "User account information"
      ],
      "description": "A description of the schema. CommonMark syntax MAY be used."
    },
    "__schema19": {
      "title": "default",
      "examples": [
        "default value",
        0,
        false,
        null
      ],
      "description": "The default value for this schema."
    },
    "__schema20": {
      "title": "example",
      "examples": [
        "John Doe",
        42,
        {
          "id": 1
        }
      ],
      "description": "An example value for this schema."
    },
    "__schema21": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema22"
      },
      "title": "examples",
      "description": "Array of example values."
    },
    "__schema23": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema24"
      },
      "title": "enum",
      "description": "An array of valid values for this schema."
    },
    "__schema25": {
      "title": "const",
      "description": "A constant value that this schema must match."
    },
    "__schema26": {
      "title": "discriminator",
      "$ref": "#/$defs/__schema27"
    },
    "__schema27": {
      "type": "object",
      "properties": {
        "propertyName": {
          "$ref": "#/$defs/__schema28"
        },
        "mapping": {
          "$ref": "#/$defs/__schema29"
        }
      },
      "required": [
        "propertyName"
      ],
      "additionalProperties": false,
      "title": "Discriminator",
      "description": "When request bodies or response payloads may be one of a number of different schemas, a discriminator object can be used to aid in serialization, deserialization, and validation.",
      "examples": [
        {
          "propertyName": "petType",
          "mapping": {
            "dog": "#/components/schemas/Dog"
          }
        }
      ]
    },
    "__schema28": {
      "type": "string",
      "title": "propertyName",
      "description": "The name of the property in the payload that will hold the discriminator value."
    },
    "__schema29": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/__schema30"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema31"
      },
      "title": "mapping",
      "description": "An object to hold mappings between payload values and schema names or references."
    },
    "__schema30": {
      "type": "string"
    },
    "__schema31": {
      "type": "string"
    },
    "__schema33": {
      "title": "xml",
      "$ref": "#/$defs/__schema34"
    },
    "__schema34": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/__schema35"
        },
        "namespace": {
          "$ref": "#/$defs/__schema36"
        },
        "prefix": {
          "$ref": "#/$defs/__schema37"
        },
        "attribute": {
          "$ref": "#/$defs/__schema38"
        },
        "wrapped": {
          "$ref": "#/$defs/__schema40"
        }
      },
      "additionalProperties": false,
      "title": "XML",
      "description": "A metadata object that allows for more fine-tuned XML model definitions.",
      "examples": [
        {
          "name": "animal",
          "wrapped": true
        }
      ]
    },
    "__schema35": {
      "type": "string",
      "title": "name",
      "description": "Replaces the name of the element/attribute used for the described schema property."
    },
    "__schema36": {
      "type": "string",
      "format": "uri",
      "title": "namespace",
      "description": "The URI of the namespace definition."
    },
    "__schema37": {
      "type": "string",
      "title": "prefix",
      "description": "The prefix to be used for the name."
    },
    "__schema38": {
      "description": "Declares whether the property definition translates to an attribute instead of an element.",
      "title": "attribute",
      "$ref": "#/$defs/__schema39"
    },
    "__schema39": {
      "type": "boolean"
    },
    "__schema40": {
      "description": "May be used only for an array definition. Signifies whether the array is wrapped or not.",
      "title": "wrapped",
      "$ref": "#/$defs/__schema41"
    },
    "__schema41": {
      "type": "boolean"
    },
    "__schema43": {
      "title": "externalDocs",
      "$ref": "#/$defs/__schema44"
    },
    "__schema44": {
      "type": "object",
      "properties": {
        "description": {
          "$ref": "#/$defs/__schema45"
        },
        "url": {
          "$ref": "#/$defs/__schema46"
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": false,
      "title": "ExternalDocumentation",
      "description": "Allows referencing an external resource for extended documentation.",
      "examples": [
        {
          "description": "Find more info here",
          "url": "https://docs.example.com"
        }
      ]
    },
    "__schema45": {
      "type": "string",
      "title": "description",
      "description": "A short description of the target documentation."
    },
    "__schema46": {
      "type": "string",
      "format": "uri",
      "title": "url",
      "description": "The URL for the target documentation."
    },
    "__schema48": {
      "type": "boolean",
      "title": "readOnly",
      "examples": [
        true
      ],
      "description": "When true, the property is only returned in responses, not accepted in requests."
    },
    "__schema49": {
      "type": "boolean",
      "title": "writeOnly",
      "examples": [
        true
      ],
      "description": "When true, the property is only accepted in requests, not returned in responses."
    },
    "__schema50": {
      "type": "boolean",
      "title": "deprecated",
      "examples": [
        true
      ],
      "description": "When true, indicates this schema is deprecated and should be avoided."
    },
    "__schema51": {
      "minItems": 1,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema52"
      },
      "title": "type"
    },
    "__schema52": {
      "type": "string",
      "enum": [
        "string",
        "number",
        "integer",
        "boolean",
        "null",
        "array",
        "object"
      ]
    },
    "__schema54": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema17"
        },
        "description": {
          "$ref": "#/$defs/__schema18"
        },
        "default": {
          "$ref": "#/$defs/__schema19"
        },
        "example": {
          "$ref": "#/$defs/__schema20"
        },
        "examples": {
          "$ref": "#/$defs/__schema21"
        },
        "enum": {
          "$ref": "#/$defs/__schema23"
        },
        "const": {
          "$ref": "#/$defs/__schema25"
        },
        "discriminator": {
          "$ref": "#/$defs/__schema26"
        },
        "xml": {
          "$ref": "#/$defs/__schema33"
        },
        "externalDocs": {
          "$ref": "#/$defs/__schema43"
        },
        "readOnly": {
          "$ref": "#/$defs/__schema48"
        },
        "writeOnly": {
          "$ref": "#/$defs/__schema49"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema50"
        },
        "type": {
          "$ref": "#/$defs/__schema55"
        },
        "format": {
          "$ref": "#/$defs/__schema56"
        },
        "pattern": {
          "$ref": "#/$defs/__schema57"
        },
        "minLength": {
          "$ref": "#/$defs/__schema58"
        },
        "maxLength": {
          "$ref": "#/$defs/__schema60"
        },
        "contentEncoding": {
          "$ref": "#/$defs/__schema62"
        },
        "contentMediaType": {
          "$ref": "#/$defs/__schema64"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "title": "String Object",
      "description": "A String Object defines the shape of a string value.",
      "examples": [
        {
          "type": "string",
          "format": "email"
        },
        {
          "type": "string",
          "pattern": "^[a-zA-Z0-9]+$"
        },
        {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        }
      ]
    },
    "__schema55": {
      "type": "string",
      "const": "string"
    },
    "__schema56": {
      "type": "string",
      "enum": [
        "date-time",
        "date",
        "time",
        "duration",
        "email",
        "idn-email",
        "hostname",
        "idn-hostname",
        "ipv4",
        "ipv6",
        "uri",
        "uri-reference",
        "iri",
        "iri-reference",
        "uri-template",
        "uuid",
        "json-pointer",
        "relative-json-pointer",
        "regex",
        "password",
        "byte",
        "binary"
      ],
      "title": "format",
      "examples": [
        "date-time",
        "date",
        "email",
        "uuid",
        "uri",
        "hostname",
        "ipv4",
        "byte",
        "binary",
        "password"
      ],
      "description": "Semantic format hint for string values. Common formats: date-time, email, uuid, uri, hostname, ipv4, byte, binary."
    },
    "__schema57": {
      "type": "string",
      "title": "Pattern",
      "description": "A regular expression pattern the string must match.",
      "examples": [
        "^[a-zA-Z0-9]+$",
        "^\\d{3}-\\d{2}-\\d{4}$"
      ]
    },
    "__schema58": {
      "title": "Minimum Length",
      "description": "Minimum string length.",
      "examples": [
        0,
        1,
        10
      ],
      "$ref": "#/$defs/__schema59"
    },
    "__schema59": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "__schema60": {
      "title": "Maximum Length",
      "description": "Maximum string length.",
      "examples": [
        255,
        1024
      ],
      "$ref": "#/$defs/__schema61"
    },
    "__schema61": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "__schema62": {
      "title": "contentEncoding",
      "description": "Encoding for binary string content.",
      "examples": [
        "base64",
        "base64url"
      ],
      "$ref": "#/$defs/__schema63"
    },
    "__schema63": {
      "type": "string"
    },
    "__schema64": {
      "title": "contentMediaType",
      "description": "Media type of the encoded string content.",
      "examples": [
        "application/octet-stream",
        "image/png"
      ],
      "$ref": "#/$defs/__schema65"
    },
    "__schema65": {
      "type": "string"
    },
    "__schema66": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema17"
        },
        "description": {
          "$ref": "#/$defs/__schema18"
        },
        "default": {
          "$ref": "#/$defs/__schema19"
        },
        "example": {
          "$ref": "#/$defs/__schema20"
        },
        "examples": {
          "$ref": "#/$defs/__schema21"
        },
        "enum": {
          "$ref": "#/$defs/__schema23"
        },
        "const": {
          "$ref": "#/$defs/__schema25"
        },
        "discriminator": {
          "$ref": "#/$defs/__schema26"
        },
        "xml": {
          "$ref": "#/$defs/__schema33"
        },
        "externalDocs": {
          "$ref": "#/$defs/__schema43"
        },
        "readOnly": {
          "$ref": "#/$defs/__schema48"
        },
        "writeOnly": {
          "$ref": "#/$defs/__schema49"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema50"
        },
        "type": {
          "$ref": "#/$defs/__schema67"
        },
        "format": {
          "$ref": "#/$defs/__schema68"
        },
        "multipleOf": {
          "$ref": "#/$defs/__schema69"
        },
        "minimum": {
          "$ref": "#/$defs/__schema71"
        },
        "maximum": {
          "$ref": "#/$defs/__schema73"
        },
        "exclusiveMinimum": {
          "$ref": "#/$defs/__schema75"
        },
        "exclusiveMaximum": {
          "$ref": "#/$defs/__schema77"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "title": "Number Object",
      "description": "A Number Object defines the shape of a number value.",
      "examples": [
        {
          "type": "number",
          "format": "float"
        },
        {
          "type": "number",
          "multipleOf": 0.5
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 100
        }
      ]
    },
    "__schema67": {
      "type": "string",
      "const": "number"
    },
    "__schema68": {
      "type": "string",
      "enum": [
        "float",
        "double"
      ],
      "title": "format",
      "examples": [
        "float",
        "double"
      ],
      "description": "Number precision format. Use 'float' for 32-bit single-precision or 'double' (default) for 64-bit double-precision IEEE 754."
    },
    "__schema69": {
      "title": "multipleOf",
      "description": "Require the number to be a multiple of this value.",
      "examples": [
        0.5,
        1,
        10
      ],
      "$ref": "#/$defs/__schema70"
    },
    "__schema70": {
      "type": "number"
    },
    "__schema71": {
      "title": "minimum",
      "description": "Inclusive lower bound for the number.",
      "examples": [
        0,
        1,
        -10
      ],
      "$ref": "#/$defs/__schema72"
    },
    "__schema72": {
      "type": "number"
    },
    "__schema73": {
      "title": "maximum",
      "description": "Inclusive upper bound for the number.",
      "examples": [
        100,
        1000
      ],
      "$ref": "#/$defs/__schema74"
    },
    "__schema74": {
      "type": "number"
    },
    "__schema75": {
      "title": "exclusiveMinimum",
      "description": "Exclusive lower bound (instance must be > this value).",
      "examples": [
        0,
        1
      ],
      "$ref": "#/$defs/__schema76"
    },
    "__schema76": {
      "type": "number"
    },
    "__schema77": {
      "title": "exclusiveMaximum",
      "description": "Exclusive upper bound (instance must be < this value).",
      "examples": [
        100,
        1000
      ],
      "$ref": "#/$defs/__schema78"
    },
    "__schema78": {
      "type": "number"
    },
    "__schema79": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema17"
        },
        "description": {
          "$ref": "#/$defs/__schema18"
