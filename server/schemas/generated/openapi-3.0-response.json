{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "$ref": "#/$defs/__schema0"
    },
    {
      "$ref": "#/$defs/__schema8"
    }
  ],
  "title": "Response",
  "description": "Describes a single response from an API Operation.",
  "$defs": {
    "__schema0": {
      "type": "object",
      "properties": {
        "$ref": {
          "$ref": "#/$defs/__schema1"
        },
        "summary": {
          "$ref": "#/$defs/__schema5"
        },
        "description": {
          "$ref": "#/$defs/__schema6"
        }
      },
      "required": [
        "$ref"
      ],
      "additionalProperties": false,
      "title": "Reference Object",
      "description": "A reference to another component in the specification.",
      "examples": [
        {
          "$ref": "#/components/schemas/Pet"
        },
        {
          "$ref": "./schemas/User.yaml",
          "summary": "A user",
          "description": "A user is a type of person."
        },
        {
          "$ref": "definitions.yaml#/Pet",
          "summary": "A pet",
          "description": "A pet is a type of animal."
        },
        {
          "$ref": "https://example.com/schemas/Pet.yaml",
          "summary": "A pet",
          "description": "A pet is a type of animal."
        }
      ]
    },
    "__schema1": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema2"
        },
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        }
      ],
      "title": "Reference",
      "description": "A reference to another component in the specification.",
      "examples": [
        "#/components/schemas/Pet",
        "https://example.com/schemas/Pet.yaml",
        "./schemas/Pet.yaml"
      ]
    },
    "__schema2": {
      "type": "string",
      "pattern": "^#.*",
      "title": "Internal JSON Pointer Reference",
      "description": "Internal JSON Pointer reference",
      "examples": [
        "#/components/schemas/User",
        "#/components/schemas/Error",
        "#/components/responses/NotFound",
        "#/components/parameters/PageParam",
        "#/components/requestBodies/UserInput"
      ]
    },
    "__schema3": {
      "type": "string",
      "pattern": "^https?:\\/\\/",
      "title": "URL Reference",
      "description": "URL reference",
      "examples": [
        "https://example.com/schemas/Pet.yaml",
        "https://example.com/schemas/User.json",
        "https://example.com/responses/Not-Found-Error.yaml",
        "https://example.com/parameters.yaml#/PageParam",
        "https://example.com/requestBodies.yaml#/requestBodies/UserInput"
      ]
    },
    "__schema4": {
      "type": "string",
      "pattern": "^[^#\\s]+(\\.ya?ml|\\.json)(#\\/.*)?$",
      "title": "Relative File Reference",
      "description": "Relative file reference",
      "examples": [
        "./schemas/Pet.yaml",
        "../common/types.yaml",
        "schemas/Pet.yaml",
        "./v2/components/parameters.yaml#/components/parameters/LimitParam",
        "../common/types.yaml#/properties/id",
        "schemas/Pet.yaml#/properties/name"
      ]
    },
    "__schema5": {
      "type": "string",
      "title": "summary",
      "description": "A short summary which by default SHOULD override that of the referenced component."
    },
    "__schema6": {
      "type": "string",
      "title": "description",
      "description": "A description which by default SHOULD override that of the referenced component."
    },
    "__schema8": {
      "type": "object",
      "properties": {
        "description": {
          "$ref": "#/$defs/__schema9"
        },
        "headers": {
          "$ref": "#/$defs/__schema10"
        },
        "content": {
          "$ref": "#/$defs/__schema143"
        },
        "links": {
          "$ref": "#/$defs/__schema168"
        }
      },
      "required": [
        "description"
      ],
      "additionalProperties": false,
      "title": "Response",
      "description": "Describes a single response from an API Operation.",
      "examples": [
        {
          "description": "Successful response",
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      ]
    },
    "__schema9": {
      "type": "string",
      "title": "description",
      "description": "A description of the response."
    },
    "__schema10": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/__schema11"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema12"
      },
      "title": "headers"
    },
    "__schema11": {
      "type": "string"
    },
    "__schema12": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema0"
        },
        {
          "$ref": "#/$defs/__schema13"
        }
      ],
      "title": "Header",
      "description": "The Header Object follows the structure of the Parameter Object."
    },
    "__schema13": {
      "type": "object",
      "properties": {
        "description": {
          "$ref": "#/$defs/__schema14"
        },
        "required": {
          "$ref": "#/$defs/__schema15"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema17"
        },
        "allowEmptyValue": {
          "$ref": "#/$defs/__schema19"
        },
        "style": {
          "$ref": "#/$defs/__schema21"
        },
        "explode": {
          "$ref": "#/$defs/__schema22"
        },
        "allowReserved": {
          "$ref": "#/$defs/__schema24"
        },
        "schema": {
          "$ref": "#/$defs/__schema26"
        },
        "example": {
          "$ref": "#/$defs/__schema128"
        },
        "examples": {
          "$ref": "#/$defs/__schema130"
        },
        "content": {
          "$ref": "#/$defs/__schema139"
        }
      },
      "additionalProperties": false,
      "title": "Header",
      "description": "The Header Object follows the structure of the Parameter Object.",
      "examples": [
        {
          "description": "Rate limit remaining",
          "schema": {
            "type": "integer"
          }
        }
      ]
    },
    "__schema14": {
      "type": "string",
      "title": "description",
      "description": "A brief description of the parameter."
    },
    "__schema15": {
      "description": "Determines whether this parameter is mandatory.",
      "title": "required",
      "$ref": "#/$defs/__schema16"
    },
    "__schema16": {
      "type": "boolean"
    },
    "__schema17": {
      "description": "Specifies that a parameter is deprecated.",
      "title": "deprecated",
      "$ref": "#/$defs/__schema18"
    },
    "__schema18": {
      "type": "boolean"
    },
    "__schema19": {
      "description": "Sets the ability to pass empty-valued parameters.",
      "title": "allowEmptyValue",
      "$ref": "#/$defs/__schema20"
    },
    "__schema20": {
      "type": "boolean"
    },
    "__schema21": {
      "type": "string",
      "const": "simple",
      "title": "style",
      "description": "Describes how the parameter value will be serialized."
    },
    "__schema22": {
      "title": "explode",
      "$ref": "#/$defs/__schema23"
    },
    "__schema23": {
      "type": "boolean"
    },
    "__schema24": {
      "title": "allowReserved",
      "$ref": "#/$defs/__schema25"
    },
    "__schema25": {
      "type": "boolean"
    },
    "__schema26": {
      "title": "schema",
      "$ref": "#/$defs/__schema27"
    },
    "__schema27": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema0"
        },
        {
          "$ref": "#/$defs/__schema28"
        },
        {
          "$ref": "#/$defs/__schema69"
        },
        {
          "$ref": "#/$defs/__schema82"
        },
        {
          "$ref": "#/$defs/__schema95"
        },
        {
          "$ref": "#/$defs/__schema97"
        },
        {
          "$ref": "#/$defs/__schema107"
        },
        {
          "$ref": "#/$defs/__schema119"
        }
      ],
      "title": "Schema Object",
      "description": "A Schema Object defines the shape of a JSON value.",
      "examples": [
        {
          "type": "string",
          "format": "email"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "__schema28": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema29"
        },
        "description": {
          "$ref": "#/$defs/__schema30"
        },
        "default": {
          "$ref": "#/$defs/__schema31"
        },
        "example": {
          "$ref": "#/$defs/__schema32"
        },
        "enum": {
          "$ref": "#/$defs/__schema33"
        },
        "discriminator": {
          "$ref": "#/$defs/__schema35"
        },
        "xml": {
          "$ref": "#/$defs/__schema42"
        },
        "externalDocs": {
          "$ref": "#/$defs/__schema52"
        },
        "readOnly": {
          "$ref": "#/$defs/__schema57"
        },
        "writeOnly": {
          "$ref": "#/$defs/__schema58"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema59"
        },
        "nullable": {
          "$ref": "#/$defs/__schema60"
        },
        "type": {
          "$ref": "#/$defs/__schema61"
        },
        "format": {
          "$ref": "#/$defs/__schema62"
        },
        "pattern": {
          "$ref": "#/$defs/__schema63"
        },
        "minLength": {
          "$ref": "#/$defs/__schema64"
        },
        "maxLength": {
          "$ref": "#/$defs/__schema66"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "title": "String Object",
      "description": "A String Object defines the shape of a string value.",
      "examples": [
        {
          "type": "string",
          "format": "email"
        },
        {
          "type": "string",
          "pattern": "^[a-zA-Z0-9]+$"
        },
        {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        }
      ]
    },
    "__schema29": {
      "type": "string",
      "title": "title",
      "examples": [
        "Pet",
        "User",
        "Order",
        "Error"
      ],
      "description": "A title for the schema, used for documentation."
    },
    "__schema30": {
      "type": "string",
      "title": "description",
      "examples": [
        "A pet in the store",
        "User account information"
      ],
      "description": "A description of the schema. CommonMark syntax MAY be used."
    },
    "__schema31": {
      "title": "default",
      "examples": [
        "default value",
        0,
        false,
        null
      ],
      "description": "The default value for this schema."
    },
    "__schema32": {
      "title": "example",
      "examples": [
        "John Doe",
        42,
        {
          "id": 1
        }
      ],
      "description": "An example value for this schema."
    },
    "__schema33": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema34"
      },
      "title": "enum",
      "description": "An array of valid values for this schema."
    },
    "__schema35": {
      "title": "discriminator",
      "$ref": "#/$defs/__schema36"
    },
    "__schema36": {
      "type": "object",
      "properties": {
        "propertyName": {
          "$ref": "#/$defs/__schema37"
        },
        "mapping": {
          "$ref": "#/$defs/__schema38"
        }
      },
      "required": [
        "propertyName"
      ],
      "additionalProperties": false,
      "title": "Discriminator",
      "description": "When request bodies or response payloads may be one of a number of different schemas, a discriminator object can be used to aid in serialization, deserialization, and validation.",
      "examples": [
        {
          "propertyName": "petType",
          "mapping": {
            "dog": "#/components/schemas/Dog"
          }
        }
      ]
    },
    "__schema37": {
      "type": "string",
      "title": "propertyName",
      "description": "The name of the property in the payload that will hold the discriminator value."
    },
    "__schema38": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/__schema39"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema40"
      },
      "title": "mapping",
      "description": "An object to hold mappings between payload values and schema names or references."
    },
    "__schema39": {
      "type": "string"
    },
    "__schema40": {
      "type": "string"
    },
    "__schema42": {
      "title": "xml",
      "$ref": "#/$defs/__schema43"
    },
    "__schema43": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/__schema44"
        },
        "namespace": {
          "$ref": "#/$defs/__schema45"
        },
        "prefix": {
          "$ref": "#/$defs/__schema46"
        },
        "attribute": {
          "$ref": "#/$defs/__schema47"
        },
        "wrapped": {
          "$ref": "#/$defs/__schema49"
        }
      },
      "additionalProperties": false,
      "title": "XML",
      "description": "A metadata object that allows for more fine-tuned XML model definitions.",
      "examples": [
        {
          "name": "animal",
          "wrapped": true
        }
      ]
    },
    "__schema44": {
      "type": "string",
      "title": "name",
      "description": "Replaces the name of the element/attribute used for the described schema property."
    },
    "__schema45": {
      "type": "string",
      "format": "uri",
      "title": "namespace",
      "description": "The URI of the namespace definition."
    },
    "__schema46": {
      "type": "string",
      "title": "prefix",
      "description": "The prefix to be used for the name."
    },
    "__schema47": {
      "description": "Declares whether the property definition translates to an attribute instead of an element.",
      "title": "attribute",
      "$ref": "#/$defs/__schema48"
    },
    "__schema48": {
      "type": "boolean"
    },
    "__schema49": {
      "description": "May be used only for an array definition. Signifies whether the array is wrapped or not.",
      "title": "wrapped",
      "$ref": "#/$defs/__schema50"
    },
    "__schema50": {
      "type": "boolean"
    },
    "__schema52": {
      "title": "externalDocs",
      "$ref": "#/$defs/__schema53"
    },
    "__schema53": {
      "type": "object",
      "properties": {
        "description": {
          "$ref": "#/$defs/__schema54"
        },
        "url": {
          "$ref": "#/$defs/__schema55"
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": false,
      "title": "ExternalDocumentation",
      "description": "Allows referencing an external resource for extended documentation.",
      "examples": [
        {
          "description": "Find more info here",
          "url": "https://docs.example.com"
        }
      ]
    },
    "__schema54": {
      "type": "string",
      "title": "description",
      "description": "A short description of the target documentation."
    },
    "__schema55": {
      "type": "string",
      "format": "uri",
      "title": "url",
      "description": "The URL for the target documentation."
    },
    "__schema57": {
      "type": "boolean",
      "title": "readOnly",
      "examples": [
        true
      ],
      "description": "When true, the property is only returned in responses, not accepted in requests."
    },
    "__schema58": {
      "type": "boolean",
      "title": "writeOnly",
      "examples": [
        true
      ],
      "description": "When true, the property is only accepted in requests, not returned in responses."
    },
    "__schema59": {
      "type": "boolean",
      "title": "deprecated",
      "examples": [
        true
      ],
      "description": "When true, indicates this schema is deprecated and should be avoided."
    },
    "__schema60": {
      "type": "boolean",
      "title": "nullable",
      "examples": [
        true,
        false
      ],
      "description": "OpenAPI 3.0: Set to true to allow null values."
    },
    "__schema61": {
      "type": "string",
      "const": "string"
    },
    "__schema62": {
      "type": "string",
      "enum": [
        "date-time",
        "date",
        "time",
        "duration",
        "email",
        "idn-email",
        "hostname",
        "idn-hostname",
        "ipv4",
        "ipv6",
        "uri",
        "uri-reference",
        "iri",
        "iri-reference",
        "uri-template",
        "uuid",
        "json-pointer",
        "relative-json-pointer",
        "regex",
        "password",
        "byte",
        "binary"
      ],
      "title": "format",
      "examples": [
        "date-time",
        "date",
        "email",
        "uuid",
        "uri",
        "hostname",
        "ipv4",
        "byte",
        "binary",
        "password"
      ],
      "description": "Semantic format hint for string values. Common formats: date-time, email, uuid, uri, hostname, ipv4, byte, binary."
    },
    "__schema63": {
      "type": "string",
      "title": "Pattern",
      "description": "A regular expression pattern the string must match.",
      "examples": [
        "^[a-zA-Z0-9]+$",
        "^\\d{3}-\\d{2}-\\d{4}$"
      ]
    },
    "__schema64": {
      "title": "Minimum Length",
      "description": "Minimum string length.",
      "examples": [
        0,
        1,
        10
      ],
      "$ref": "#/$defs/__schema65"
    },
    "__schema65": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "__schema66": {
      "title": "Maximum Length",
      "description": "Maximum string length.",
      "examples": [
        255,
        1024
      ],
      "$ref": "#/$defs/__schema67"
    },
    "__schema67": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "__schema69": {
