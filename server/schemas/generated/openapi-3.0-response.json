        },
        "xml": {
          "$ref": "#/$defs/__schema42"
        },
        "externalDocs": {
          "$ref": "#/$defs/__schema52"
        },
        "readOnly": {
          "$ref": "#/$defs/__schema57"
        },
        "writeOnly": {
          "$ref": "#/$defs/__schema58"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema59"
        },
        "nullable": {
          "$ref": "#/$defs/__schema60"
        },
        "type": {
          "$ref": "#/$defs/__schema70"
        },
        "format": {
          "$ref": "#/$defs/__schema71"
        },
        "multipleOf": {
          "$ref": "#/$defs/__schema72"
        },
        "minimum": {
          "$ref": "#/$defs/__schema74"
        },
        "maximum": {
          "$ref": "#/$defs/__schema76"
        },
        "exclusiveMinimum": {
          "$ref": "#/$defs/__schema78"
        },
        "exclusiveMaximum": {
          "$ref": "#/$defs/__schema80"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "title": "Number Object",
      "description": "A Number Object defines the shape of a number value.",
      "examples": [
        {
          "type": "number",
          "format": "float"
        },
        {
          "type": "number",
          "multipleOf": 0.5
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        {
          "type": "number",
          "minimum": 0,
          "exclusiveMinimum": true
        }
      ]
    },
    "__schema70": {
      "type": "string",
      "const": "number"
    },
    "__schema71": {
      "type": "string",
      "enum": [
        "float",
        "double"
      ],
      "title": "format",
      "examples": [
        "float",
        "double"
      ],
      "description": "Number precision format. Use 'float' for 32-bit single-precision or 'double' (default) for 64-bit double-precision IEEE 754."
    },
    "__schema72": {
      "title": "multipleOf",
      "description": "Require the number to be a multiple of this value.",
      "examples": [
        0.5,
        1,
        10
      ],
      "$ref": "#/$defs/__schema73"
    },
    "__schema73": {
      "type": "number"
    },
    "__schema74": {
      "title": "minimum",
      "description": "Inclusive lower bound for the number.",
      "examples": [
        0,
        1,
        -10
      ],
      "$ref": "#/$defs/__schema75"
    },
    "__schema75": {
      "type": "number"
    },
    "__schema76": {
      "title": "maximum",
      "description": "Inclusive upper bound for the number.",
      "examples": [
