        true,
        false
      ],
      "$ref": "#/$defs/__schema79"
    },
    "__schema79": {
      "type": "boolean"
    },
    "__schema80": {
      "title": "exclusiveMaximum",
      "description": "When true, the maximum value is exclusive (value must be < maximum).",
