{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "$ref": "#/$defs/__schema0"
    },
    {
      "$ref": "#/$defs/__schema8"
    }
  ],
  "title": "Parameter",
  "description": "Describes a single operation parameter.",
  "$defs": {
    "__schema0": {
      "type": "object",
      "properties": {
        "$ref": {
          "$ref": "#/$defs/__schema1"
        },
        "summary": {
          "$ref": "#/$defs/__schema5"
        },
        "description": {
          "$ref": "#/$defs/__schema6"
        }
      },
      "required": [
        "$ref"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/__schema7"
      },
      "title": "Reference Object",
      "description": "A reference to another component in the specification.",
      "examples": [
        {
          "$ref": "#/components/schemas/Pet"
        },
        {
          "$ref": "./schemas/User.yaml",
          "summary": "A user",
          "description": "A user is a type of person."
        },
        {
          "$ref": "definitions.yaml#/Pet",
          "summary": "A pet",
          "description": "A pet is a type of animal."
        },
        {
          "$ref": "https://example.com/schemas/Pet.yaml",
          "summary": "A pet",
          "description": "A pet is a type of animal."
        }
      ]
    },
    "__schema1": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema2"
        },
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        }
      ],
      "title": "Reference",
      "description": "A reference to another component in the specification.",
      "examples": [
        "#/components/schemas/Pet",
        "https://example.com/schemas/Pet.yaml",
        "./schemas/Pet.yaml"
      ]
    },
    "__schema2": {
      "type": "string",
      "pattern": "^#.*",
      "title": "Internal JSON Pointer Reference",
      "description": "Internal JSON Pointer reference",
      "examples": [
        "#/components/schemas/User",
        "#/components/schemas/Error",
        "#/components/responses/NotFound",
        "#/components/parameters/PageParam",
        "#/components/requestBodies/UserInput"
      ]
    },
    "__schema3": {
      "type": "string",
      "pattern": "^https?:\\/\\/",
      "title": "URL Reference",
      "description": "URL reference",
      "examples": [
        "https://example.com/schemas/Pet.yaml",
        "https://example.com/schemas/User.json",
        "https://example.com/responses/Not-Found-Error.yaml",
        "https://example.com/parameters.yaml#/PageParam",
        "https://example.com/requestBodies.yaml#/requestBodies/UserInput"
      ]
    },
    "__schema4": {
      "type": "string",
      "pattern": "^[^#\\s]+(\\.ya?ml|\\.json)(#\\/.*)?$",
      "title": "Relative File Reference",
      "description": "Relative file reference",
      "examples": [
        "./schemas/Pet.yaml",
        "../common/types.yaml",
        "schemas/Pet.yaml",
        "./v2/components/parameters.yaml#/components/parameters/LimitParam",
        "../common/types.yaml#/properties/id",
        "schemas/Pet.yaml#/properties/name"
      ]
    },
    "__schema5": {
      "type": "string",
      "title": "summary",
      "description": "A short summary which by default SHOULD override that of the referenced component."
    },
    "__schema6": {
      "type": "string",
      "title": "description",
      "description": "A description which by default SHOULD override that of the referenced component."
    },
    "__schema7": {},
    "__schema8": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/__schema9"
        },
        "in": {
          "$ref": "#/$defs/__schema10"
        },
        "description": {
          "$ref": "#/$defs/__schema11"
        },
        "required": {
          "$ref": "#/$defs/__schema12"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema14"
        },
        "allowEmptyValue": {
          "$ref": "#/$defs/__schema16"
        },
        "style": {
          "$ref": "#/$defs/__schema18"
        },
        "explode": {
          "$ref": "#/$defs/__schema19"
        },
        "allowReserved": {
          "$ref": "#/$defs/__schema20"
        },
        "schema": {
          "$ref": "#/$defs/__schema22"
        },
        "example": {
          "$ref": "#/$defs/__schema145"
        },
        "examples": {
          "$ref": "#/$defs/__schema146"
        },
        "content": {
          "$ref": "#/$defs/__schema155"
        }
      },
      "required": [
        "name",
        "in"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/__schema203"
      },
      "title": "Parameter",
      "description": "Describes a single operation parameter.",
      "examples": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ]
    },
    "__schema9": {
      "type": "string",
      "title": "name",
      "examples": [
        "id",
        "page",
        "limit",
        "Authorization",
        "X-Request-ID",
        "status"
      ],
      "description": "The name of the parameter. Case-sensitive."
    },
    "__schema10": {
      "type": "string",
      "enum": [
        "query",
        "header",
        "path",
        "cookie"
      ],
      "title": "in",
      "examples": [
        "query",
        "path",
        "header",
        "cookie"
      ],
      "description": "Location of the parameter. 'path' parameters must have required=true."
    },
    "__schema11": {
      "type": "string",
      "title": "description",
      "examples": [
        "Unique identifier",
        "Page number for pagination",
        "Maximum items to return"
      ],
      "description": "A description of the parameter. CommonMark syntax MAY be used."
    },
    "__schema12": {
      "description": "Whether the parameter is required.",
      "title": "required",
      "examples": [
        true,
        false
      ],
      "$ref": "#/$defs/__schema13"
    },
    "__schema13": {
      "type": "boolean"
    },
    "__schema14": {
      "description": "Marks the parameter as deprecated.",
      "title": "deprecated",
      "examples": [
        true
      ],
      "$ref": "#/$defs/__schema15"
    },
    "__schema15": {
      "type": "boolean"
    },
    "__schema16": {
      "description": "For query parameters only. Allows empty values (?param=).",
      "title": "allowEmptyValue",
      "examples": [
        true
      ],
      "$ref": "#/$defs/__schema17"
    },
    "__schema17": {
      "type": "boolean"
    },
    "__schema18": {
      "type": "string",
      "enum": [
        "matrix",
        "label",
        "form",
        "simple",
        "spaceDelimited",
        "pipeDelimited",
        "deepObject"
      ],
      "title": "style",
      "examples": [
        "simple",
        "form",
        "matrix",
        "label",
        "deepObject"
      ],
      "description": "Serialization style. Defaults vary by 'in': query/cookie='form', path/header='simple'."
    },
    "__schema19": {
      "type": "boolean",
      "title": "explode",
      "examples": [
        true,
        false
      ],
      "description": "For arrays/objects. When true, each value gets its own parameter."
    },
    "__schema20": {
      "description": "For query parameters. When true, allows reserved characters without encoding.",
      "title": "allowReserved",
      "examples": [
        true
      ],
      "$ref": "#/$defs/__schema21"
    },
    "__schema21": {
      "type": "boolean"
    },
    "__schema22": {
      "title": "schema",
      "$ref": "#/$defs/__schema23"
    },
    "__schema23": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema0"
        },
        {
          "$ref": "#/$defs/__schema24"
        },
        {
          "$ref": "#/$defs/__schema66"
        },
        {
          "$ref": "#/$defs/__schema79"
        },
        {
          "$ref": "#/$defs/__schema92"
        },
        {
          "$ref": "#/$defs/__schema94"
        },
        {
          "$ref": "#/$defs/__schema112"
        },
        {
          "$ref": "#/$defs/__schema136"
        }
      ],
      "title": "Schema Object",
      "description": "A Schema Object defines the shape of a JSON value.",
      "examples": [
        {
          "type": "string",
          "format": "email"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "__schema24": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema25"
        },
        "description": {
          "$ref": "#/$defs/__schema26"
        },
        "default": {
          "$ref": "#/$defs/__schema27"
        },
        "example": {
          "$ref": "#/$defs/__schema28"
        },
        "enum": {
          "$ref": "#/$defs/__schema29"
        },
        "const": {
          "$ref": "#/$defs/__schema31"
        },
        "discriminator": {
          "$ref": "#/$defs/__schema32"
        },
        "xml": {
          "$ref": "#/$defs/__schema39"
        },
        "externalDocs": {
          "$ref": "#/$defs/__schema49"
        },
        "readOnly": {
          "$ref": "#/$defs/__schema54"
        },
        "writeOnly": {
          "$ref": "#/$defs/__schema55"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema56"
        },
        "nullable": {
          "$ref": "#/$defs/__schema57"
        },
        "type": {
          "$ref": "#/$defs/__schema58"
        },
        "format": {
          "$ref": "#/$defs/__schema59"
        },
        "pattern": {
          "$ref": "#/$defs/__schema60"
        },
        "minLength": {
          "$ref": "#/$defs/__schema61"
        },
        "maxLength": {
          "$ref": "#/$defs/__schema63"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/__schema65"
      },
      "title": "String Object",
      "description": "A String Object defines the shape of a string value.",
      "examples": [
        {
          "type": "string",
          "format": "email"
        },
        {
          "type": "string",
          "pattern": "^[a-zA-Z0-9]+$"
        },
        {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        }
      ]
    },
    "__schema25": {
      "type": "string",
      "title": "title",
      "examples": [
        "Pet",
        "User",
        "Order",
        "Error"
      ],
      "description": "A title for the schema, used for documentation."
    },
    "__schema26": {
      "type": "string",
      "title": "description",
      "examples": [
        "A pet in the store",
        "User account information"
      ],
      "description": "A description of the schema. CommonMark syntax MAY be used."
    },
    "__schema27": {
      "title": "default",
      "examples": [
        "default value",
        0,
        false,
        null
      ],
      "description": "The default value for this schema."
    },
    "__schema28": {
      "title": "example",
      "examples": [
        "John Doe",
        42,
        {
          "id": 1
        }
      ],
      "description": "An example value for this schema."
    },
    "__schema29": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema30"
      },
      "title": "enum",
      "description": "An array of valid values for this schema."
    },
    "__schema30": {},
    "__schema31": {
      "title": "const",
      "description": "A constant value that this schema must match."
    },
    "__schema32": {
      "title": "discriminator",
      "$ref": "#/$defs/__schema33"
    },
    "__schema33": {
      "type": "object",
      "properties": {
        "propertyName": {
          "$ref": "#/$defs/__schema34"
        },
        "mapping": {
          "$ref": "#/$defs/__schema35"
        }
      },
      "required": [
        "propertyName"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/__schema38"
      },
      "title": "Discriminator",
      "description": "When request bodies or response payloads may be one of a number of different schemas, a discriminator object can be used to aid in serialization, deserialization, and validation.",
      "examples": [
        {
          "propertyName": "petType",
          "mapping": {
            "dog": "#/components/schemas/Dog"
          }
        }
      ]
    },
    "__schema34": {
      "type": "string",
      "title": "propertyName",
      "description": "The name of the property in the payload that will hold the discriminator value."
    },
    "__schema35": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/__schema36"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema37"
      },
      "title": "mapping",
      "description": "An object to hold mappings between payload values and schema names or references."
    },
    "__schema36": {
      "type": "string"
    },
    "__schema37": {
      "type": "string"
    },
    "__schema38": {},
    "__schema39": {
      "title": "xml",
      "$ref": "#/$defs/__schema40"
    },
    "__schema40": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/__schema41"
        },
        "namespace": {
          "$ref": "#/$defs/__schema42"
        },
        "prefix": {
          "$ref": "#/$defs/__schema43"
        },
        "attribute": {
          "$ref": "#/$defs/__schema44"
        },
        "wrapped": {
          "$ref": "#/$defs/__schema46"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema48"
      },
      "title": "XML",
      "description": "A metadata object that allows for more fine-tuned XML model definitions.",
      "examples": [
        {
          "name": "animal",
          "wrapped": true
        }
      ]
    },
    "__schema41": {
      "type": "string",
      "title": "name",
      "description": "Replaces the name of the element/attribute used for the described schema property."
    },
    "__schema42": {
      "type": "string",
      "format": "uri",
      "title": "namespace",
      "description": "The URI of the namespace definition."
    },
    "__schema43": {
      "type": "string",
      "title": "prefix",
      "description": "The prefix to be used for the name."
    },
    "__schema44": {
      "description": "Declares whether the property definition translates to an attribute instead of an element.",
      "title": "attribute",
      "$ref": "#/$defs/__schema45"
    },
    "__schema45": {
      "type": "boolean"
    },
    "__schema46": {
      "description": "May be used only for an array definition. Signifies whether the array is wrapped or not.",
      "title": "wrapped",
      "$ref": "#/$defs/__schema47"
    },
    "__schema47": {
      "type": "boolean"
    },
    "__schema48": {},
    "__schema49": {
      "title": "externalDocs",
      "$ref": "#/$defs/__schema50"
    },
    "__schema50": {
      "type": "object",
      "properties": {
        "description": {
          "$ref": "#/$defs/__schema51"
        },
        "url": {
          "$ref": "#/$defs/__schema52"
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/__schema53"
      },
      "title": "ExternalDocumentation",
      "description": "Allows referencing an external resource for extended documentation.",
      "examples": [
        {
          "description": "Find more info here",
          "url": "https://docs.example.com"
        }
      ]
    },
    "__schema51": {
      "type": "string",
      "title": "description",
      "description": "A short description of the target documentation."
    },
    "__schema52": {
      "type": "string",
      "format": "uri",
      "title": "url",
      "description": "The URL for the target documentation."
    },
    "__schema53": {},
    "__schema54": {
      "type": "boolean",
      "title": "readOnly",
      "examples": [
        true
      ],
      "description": "When true, the property is only returned in responses, not accepted in requests."
    },
    "__schema55": {
      "type": "boolean",
      "title": "writeOnly",
      "examples": [
        true
      ],
      "description": "When true, the property is only accepted in requests, not returned in responses."
    },
    "__schema56": {
      "type": "boolean",
      "title": "deprecated",
      "examples": [
        true
      ],
      "description": "When true, indicates this schema is deprecated and should be avoided."
    },
    "__schema57": {
      "type": "boolean",
      "title": "nullable",
      "examples": [
        true,
        false
      ],
      "description": "OpenAPI 3.0: Set to true to allow null values."
    },
    "__schema58": {
      "type": "string",
      "const": "string"
    },
    "__schema59": {
      "type": "string",
      "enum": [
        "date-time",
        "date",
        "time",
        "duration",
        "email",
        "idn-email",
        "hostname",
        "idn-hostname",
        "ipv4",
        "ipv6",
        "uri",
        "uri-reference",
        "iri",
        "iri-reference",
        "uri-template",
        "uuid",
        "json-pointer",
        "relative-json-pointer",
        "regex",
        "password",
        "byte",
        "binary"
      ],
      "title": "format",
      "examples": [
        "date-time",
        "date",
        "email",
        "uuid",
        "uri",
        "hostname",
        "ipv4",
        "byte",
        "binary",
        "password"
      ],
      "description": "Semantic format hint for string values. Common formats: date-time, email, uuid, uri, hostname, ipv4, byte, binary."
    },
    "__schema60": {
      "type": "string",
      "title": "Pattern",
      "description": "A regular expression pattern the string must match.",
      "examples": [
        "^[a-zA-Z0-9]+$",
        "^\\d{3}-\\d{2}-\\d{4}$"
      ]
    },
    "__schema61": {
      "title": "Minimum Length",
      "description": "Minimum string length.",
      "examples": [
        0,
        1,
        10
      ],
      "$ref": "#/$defs/__schema62"
    },
    "__schema62": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "__schema63": {
      "title": "Maximum Length",
      "description": "Maximum string length.",
      "examples": [
        255,
        1024
      ],
      "$ref": "#/$defs/__schema64"
    },
    "__schema64": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "__schema65": {},
    "__schema66": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema25"
        },
        "description": {
          "$ref": "#/$defs/__schema26"
        },
        "default": {
          "$ref": "#/$defs/__schema27"
        },
        "example": {
          "$ref": "#/$defs/__schema28"
        },
        "enum": {
          "$ref": "#/$defs/__schema29"
        },
        "const": {
          "$ref": "#/$defs/__schema31"
        },
        "discriminator": {
          "$ref": "#/$defs/__schema32"
        },
        "xml": {
          "$ref": "#/$defs/__schema39"
        },
        "externalDocs": {
          "$ref": "#/$defs/__schema49"
        },
        "readOnly": {
          "$ref": "#/$defs/__schema54"
        },
        "writeOnly": {
          "$ref": "#/$defs/__schema55"
        },
        "deprecated": {
          "$ref": "#/$defs/__schema56"
        },
        "nullable": {
          "$ref": "#/$defs/__schema57"
        },
        "type": {
          "$ref": "#/$defs/__schema67"
        },
        "format": {
          "$ref": "#/$defs/__schema68"
        },
        "multipleOf": {
          "$ref": "#/$defs/__schema69"
        },
        "minimum": {
          "$ref": "#/$defs/__schema71"
        },
        "maximum": {
          "$ref": "#/$defs/__schema73"
        },
        "exclusiveMinimum": {
          "$ref": "#/$defs/__schema75"
        },
        "exclusiveMaximum": {
          "$ref": "#/$defs/__schema77"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/__schema65"
      },
      "title": "Number Object",
      "description": "A Number Object defines the shape of a number value.",
      "examples": [
        {
          "type": "number",
          "format": "float"
        },
        {
          "type": "number",
          "multipleOf": 0.5
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 100
        }
      ]
    },
    "__schema67": {
      "type": "string",
      "const": "number"
    },
    "__schema68": {
      "type": "string",
      "enum": [
        "float",
        "double"
      ],
      "title": "format",
      "examples": [
        "float",
        "double"
      ],
      "description": "Number precision format. Use 'float' for 32-bit single-precision or 'double' (default) for 64-bit double-precision IEEE 754."
    },
    "__schema69": {
      "title": "multipleOf",
      "description": "Require the number to be a multiple of this value.",
      "examples": [
        0.5,
        1,
        10
      ],
      "$ref": "#/$defs/__schema70"
    },
    "__schema70": {
      "type": "number"
    },
    "__schema71": {
      "title": "minimum",
      "description": "Inclusive lower bound for the number.",
      "examples": [
        0,
        1,
        -10
      ],
      "$ref": "#/$defs/__schema72"
    },
    "__schema72": {
      "type": "number"
    },
    "__schema73": {
      "title": "maximum",
      "description": "Inclusive upper bound for the number.",
      "examples": [
        100,
        1000
      ],
      "$ref": "#/$defs/__schema74"
    },
    "__schema74": {
      "type": "number"
    },
    "__schema75": {
      "title": "exclusiveMinimum",
      "description": "Exclusive lower bound (instance must be > this value).",
      "examples": [
        0,
        1
      ],
      "$ref": "#/$defs/__schema76"
    },
    "__schema76": {
      "type": "number"
    },
    "__schema77": {
      "title": "exclusiveMaximum",
      "description": "Exclusive upper bound (instance must be < this value).",
      "examples": [
        100,
        1000
      ],
      "$ref": "#/$defs/__schema78"
    },
    "__schema78": {
      "type": "number"
    },
    "__schema79": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/__schema25"
        },
        "description": {
          "$ref": "#/$defs/__schema26"
