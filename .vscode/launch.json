{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/client",
				"${workspaceFolder}/test-files"
			],
			"outFiles": ["${workspaceFolder}/client/dist/**/*.js"],
			"env": {
				"TELESCOPE_SERVER_PATH": "${workspaceFolder}/client/bin/telescope",
				"TELESCOPE_LOG_LEVEL": "debug",
				"TELESCOPE_DEV": "1"
			},
			"preLaunchTask": "build:all",
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 1
			}
		}
	]
}
