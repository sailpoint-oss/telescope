{
	"name": "telescope",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm --filter ./client run build",
		"build:sidecar": "pnpm --filter ./client run build:sidecar",
		"build:server": "cd server && go build -o ../client/bin/telescope .",
		"test:e2e": "pnpm --filter ./client run test:e2e --if-present",
		"trace:merge": "node ./scripts/merge-trace-logs.mjs",
		"package": "pnpm --filter ./client run build && pnpm --filter ./client run package",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"dependencies": {},
	"devDependencies": {},
	"pnpm": {
		"overrides": {
			"lodash": "4.18.0",
			"undici": "7.24.0",
			"tmp": "0.2.6",
			"qs": "6.15.2",
			"serialize-javascript": "7.0.5",
			"fast-uri": "3.1.2",
			"picomatch": "2.3.2",
			"underscore": "1.13.8",
			"markdown-it": "14.1.1",
			"ajv": "8.18.0",
			"minimatch@3": "3.1.4",
			"minimatch@5": "5.1.8",
			"minimatch@10": "10.2.3",
			"brace-expansion@1": "1.1.13",
			"brace-expansion@2": "2.0.3",
			"brace-expansion@5": "5.0.6",
			"@isaacs/brace-expansion": "5.0.6",
			"diff@5": "5.2.2",
			"diff@7": "8.0.3",
			"uuid": "11.1.1"
		}
	},
	"workspaces": [
		"client",
		"test-files"
	]
}
